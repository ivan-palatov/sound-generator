# MiniMax Token Plan Subscription Key (Billing → Token Plan)
MINIMAX_API_KEY=your_subscription_key_here

# Optional
PORT=8000
CORS_ORIGIN=http://localhost:5173

# From repo root:
#   pnpm install
#   pnpm dev          # frontend + backend in parallel
#   pnpm dev:frontend # frontend only
#   pnpm dev:backend  # backend only (requires Deno)
